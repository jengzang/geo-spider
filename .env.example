GEONODE_ENV=development
GEONODE_LOG_LEVEL=INFO
GEONODE_SQLITE_PATH=data/processed/geonode_spider.db
GEONODE_EXPORT_DIR=data/exports
GEONODE_RAW_DIR=data/raw
GEONODE_INTERIM_DIR=data/interim
GEONODE_PROCESSED_DIR=data/processed

GEONODE_REQUEST_TIMEOUT=15
GEONODE_REQUEST_RETRIES=3
GEONODE_SLEEP_MIN_SECONDS=0.5
GEONODE_SLEEP_MAX_SECONDS=1.5
GEONODE_BACKOFF_BASE_SECONDS=1.0

GEONODE_PROXY_ENABLED=false
GEONODE_PROXY_POOL=

GEONODE_GEO_PROVIDER=mock
GEONODE_GEO_API_KEY=
GEONODE_GEO_ENDPOINT=
